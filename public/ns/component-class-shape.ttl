@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

[] a sh:NodeShape ;
  sh:targetClass rdfs:Class ;
  sh:property [
    sh:name "label" ;
    sh:path rdfs:label ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] , [
    sh:name "comment" ;
    sh:path rdfs:comment ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] .
