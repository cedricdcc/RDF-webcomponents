@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:OrgShape a sh:NodeShape ;
  sh:targetClass ex:Organisation ;
  sh:property [
    sh:name "name" ;
    sh:path ex:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] , [
    sh:name "shortName" ;
    sh:path ex:shortName ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] , [
    sh:name "founded" ;
    sh:path ex:founded ;
    sh:datatype xsd:integer ;
    sh:maxCount 1 ;
  ] , [
    sh:name "url" ;
    sh:path ex:url ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] , [
    sh:name "city" ;
    sh:path ex:city ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] , [
    sh:name "focus" ;
    sh:path ex:focus ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] .
