{
  "debounceMs": 150,
  "maxConcurrentPipelines": 4,
  "decorators": {
    "enabled": true,
    "icons": { "loading": "⏳", "ready": "🔬", "error": "⚠" }
  },
  "rules": [
    {
      "id": "regex-ttl-n3",
      "match": {
        "urlRegex": "\\.(ttl|n3|nt)(\\?.*)?$",
        "contentType": "text"
      },
      "adapter": { "strategy": "file", "cache": "none" },
      "lens": {
        "shapeFile": "/demo/shapes.ttl",
        "shapeClass": "http://example.org/Person",
        "multiple": true
      },
      "display": {
        "template": "/demo/person-card.html",
        "mode": "grid"
      }
    }
  ]
}
